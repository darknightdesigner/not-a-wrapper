# =============================================================================
# Not A Wrapper Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk Authentication (Required)
# -----------------------------------------------------------------------------
# Get these from your Clerk dashboard: https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk JWT Issuer Domain (Required for Convex auth)
# Find in Clerk Dashboard > API Keys > look for "Frontend API" or "JWT Issuer"
# Format: https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# Clerk Webhook Secret (for user sync - set up in Clerk Dashboard > Webhooks)
CLERK_WEBHOOK_SECRET=

# Clerk URLs (customize if using custom auth pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# -----------------------------------------------------------------------------
# Convex Database (Required)
# -----------------------------------------------------------------------------
# Get these after running: npx convex dev
# Or from your Convex dashboard: https://dashboard.convex.dev/
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# -----------------------------------------------------------------------------
# Security (Required)
# -----------------------------------------------------------------------------
# CSRF protection secret - generate a secure random string
# Generate with: openssl rand -base64 32
CSRF_SECRET=

# Encryption key for user API keys - MUST be exactly 32 bytes, base64 encoded
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# AI Provider API Keys (at least one required)
# -----------------------------------------------------------------------------
# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google (Gemini) - https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Mistral - https://console.mistral.ai/
MISTRAL_API_KEY=

# Perplexity - https://www.perplexity.ai/account/api/keys
PERPLEXITY_API_KEY=

# xAI (Grok) - https://console.x.ai/
XAI_API_KEY=

# OpenRouter - https://openrouter.ai/keys
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Optional Configuration
# -----------------------------------------------------------------------------
# Vercel deployment URL (automatically set by Vercel, only needed for custom setups)
# NEXT_PUBLIC_VERCEL_URL=

# Third-Party Tool API Keys (optional)
# These enable additional tool capabilities for models without native tools.
# Users can also provide their own keys via Settings → Tool Keys (overrides these).
# EXA_API_KEY=...              # Web search for Mistral/OpenRouter/Perplexity models
# FIRECRAWL_API_KEY=...        # Web scraping/extraction (future)

# Official deployment flag (enables analytics)
# NAW_OFFICIAL=true

# -----------------------------------------------------------------------------
# Future: Payments (Flowglad)
# -----------------------------------------------------------------------------
# FLOWGLAD_API_KEY=
# FLOWGLAD_WEBHOOK_SECRET=

# Experimental Flowglad Pay API (Agentic Payments)
# user_name=
# ApiKey=

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# PostHog LLM Analytics - https://posthog.com/docs/llm-analytics
# Get your project API key from: https://app.posthog.com/settings/project#api-keys

# PostHog LLM Analytics (server-side)
POSTHOG_API_KEY= #phc_your_project_api_key

# PostHog Client Analytics (optional, for page views)
NEXT_PUBLIC_POSTHOG_KEY= #phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST= #https://us.i.posthog.com


# PostHog host (use https://eu.i.posthog.com for EU data residency)
POSTHOG_HOST= #https://us.i.posthog.com

# -----------------------------------------------------------------------------
# HugeIcons Pro (for icon library access)
# -----------------------------------------------------------------------------
# Universal License Key from your HugeIcons account
# Used in .npmrc for private npm registry authentication
HUGEICONS_LICENSE_KEY=