{
  "version": "p2-v1",
  "organizationSlugEnv": "SENTRY_ORG_SLUG",
  "projectSlugEnv": "SENTRY_PROJECT_SLUG",
  "endpointTemplate": "https://sentry.io/api/0/organizations/${SENTRY_ORG_SLUG}/alert-rules/",
  "alerts": [
    {
      "id": "chat-error-rate-high",
      "name": "P2 Chat Error Rate High",
      "dedupeKey": "p2.chat.error_rate.high.v1",
      "dataset": "events",
      "environment": "production",
      "queries": {
        "numerator": "event.type:error tags[route]:api/chat",
        "denominator": "event.type:transaction transaction:\"POST /api/chat\""
      },
      "formula": "A / B",
      "thresholds": {
        "warning": 0.005,
        "critical": 0.01
      },
      "windowMinutes": 10
    },
    {
      "id": "chat-p95-latency-high",
      "name": "P2 Chat P95 Latency High",
      "dedupeKey": "p2.chat.latency.p95.high.v1",
      "dataset": "events",
      "environment": "production",
      "query": "event.type:transaction transaction:\"POST /api/chat\"",
      "aggregate": "p95(transaction.duration)",
      "thresholds": {
        "warningMs": 6000,
        "criticalMs": 8000
      },
      "windowMinutes": 15
    },
    {
      "id": "chat-provider-model-failure-rate-high",
      "name": "P2 Chat Provider/Model Failure Rate High",
      "dedupeKey": "p2.chat.provider_model.failure_rate.high.v1",
      "dataset": "events",
      "environment": "production",
      "parameters": {
        "provider": "$PROVIDER",
        "model": "$MODEL"
      },
      "queries": {
        "numerator": "event.type:error tags[route]:api/chat tags[chat_provider]:$PROVIDER tags[chat_model]:$MODEL",
        "denominator": "event.type:transaction transaction:\"POST /api/chat\" tags[chat_provider]:$PROVIDER tags[chat_model]:$MODEL"
      },
      "formula": "A / B",
      "thresholds": {
        "warning": 0.015,
        "critical": 0.03
      },
      "windowMinutes": 15
    },
    {
      "id": "chat-tool-failure-timeout-rate-high",
      "name": "P2 Chat Tool Failure/Timeout Rate High",
      "dedupeKey": "p2.chat.tools.failure_timeout_rate.high.v1",
      "dataset": "events",
      "environment": "production",
      "queries": {
        "numerator": "event.type:transaction transaction:\"POST /api/chat\" (tags[chat_tool_outcome]:timeout OR tags[chat_tool_outcome]:failure OR tags[chat_tool_outcome]:budget_denied)",
        "denominator": "event.type:transaction transaction:\"POST /api/chat\" tags[chat_tool_outcome]:!none"
      },
      "formula": "A / B",
      "thresholds": {
        "warning": 0.015,
        "critical": 0.03
      },
      "windowMinutes": 15
    },
    {
      "id": "chat-token-usage-anomaly",
      "name": "P2 Chat Token Usage Anomaly",
      "dedupeKey": "p2.chat.tokens.anomaly.v1",
      "dataset": "spans",
      "environment": "production",
      "query": "event.type:span span.op:gen_ai.stream_text tags[route]:api/chat",
      "aggregates": [
        "p95(span.data.gen_ai.usage.input_tokens)",
        "p95(span.data.gen_ai.usage.output_tokens)"
      ],
      "anomaly": {
        "comparisonWindowHours": 24,
        "triggerMultiplier": 2
      },
      "windowMinutes": 30
    },
    {
      "id": "chat-release-regression-guardrail",
      "name": "P2 Chat Release Regression Guardrail",
      "dedupeKey": "p2.chat.release.regression.v1",
      "dataset": "events",
      "environment": "production",
      "parameters": {
        "release": "$RELEASE",
        "baselineRelease": "$BASELINE_RELEASE"
      },
      "queries": {
        "errorRelease": "event.type:error tags[route]:api/chat release:$RELEASE",
        "errorBaseline": "event.type:error tags[route]:api/chat release:$BASELINE_RELEASE",
        "latencyRelease": "event.type:transaction transaction:\"POST /api/chat\" release:$RELEASE",
        "latencyBaseline": "event.type:transaction transaction:\"POST /api/chat\" release:$BASELINE_RELEASE"
      },
      "guardrails": {
        "errorRateIncreaseAbsolute": 0.005,
        "p95LatencyIncreaseRelative": 0.25
      }
    }
  ]
}
