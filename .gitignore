# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env.local
.env.development.local
.env.test.local
.env.production.local


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# env files (all variations)
.env
.env.*
!.env.example

# bun debug logs
bun-debug.log*

# AI tool skill directories (symlinked from .agents/skills/)
# The source of truth is .agents/skills/ which IS tracked in git
# Each developer runs the sync script after cloning
.cursor/skills/
.claude/skills/
.codex/skills/

# Cursor rules are tracked, but other Cursor config is ignored
.cursor/*
!.cursor/rules/

# Claude Code local settings (personal preferences)
.claude/settings.local.json

# Optional: uncomment to ignore memories directory
# memories/
